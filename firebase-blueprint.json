{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique identifier"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the user was created"
        }
      },
      "required": ["uid", "email"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A habit created by a user",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The habit's unique identifier"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who created the habit"
        },
        "name": {
          "type": "string",
          "description": "The name of the habit"
        },
        "description": {
          "type": "string",
          "description": "A description of the habit"
        },
        "frequency": {
          "type": "string",
          "description": "How often the habit should be completed"
        },
        "time": {
          "type": "string",
          "description": "The time of day the habit should be completed"
        },
        "icon": {
          "type": "string",
          "description": "The icon representing the habit"
        },
        "color": {
          "type": "string",
          "description": "The color associated with the habit"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the habit was created"
        }
      },
      "required": ["id", "userId", "name", "frequency", "time", "icon", "color"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "A daily journal entry created by a user",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The journal entry's unique identifier"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who created the journal entry"
        },
        "date": {
          "type": "string",
          "description": "The date of the journal entry"
        },
        "mood": {
          "type": "string",
          "description": "The mood for the day"
        },
        "content": {
          "type": "string",
          "description": "The content of the journal entry"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the journal entry was created"
        }
      },
      "required": ["id", "userId", "date", "mood", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles"
    },
    "/habits/{habitId}": {
      "schema": {
        "$ref": "#/entities/Habit"
      },
      "description": "Stores habits created by users"
    },
    "/journals/{journalId}": {
      "schema": {
        "$ref": "#/entities/JournalEntry"
      },
      "description": "Stores journal entries created by users"
    }
  }
}
